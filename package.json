{
  "name": "mana-engine-monorepo",
  "private": true,
  "workspaces": [
    "library",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint --deny-warnings",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "all": "bun run lint && bun run format:check && bun run typecheck && bun run test && bun run build",
    "editor": "bun run --filter 'platformer' editor",
    "dev": "bun run --filter 'platformer' dev:game",
    "dev:host": "bun run --filter 'platformer' dev:host",
    "build": "bun run --filter 'mana-engine' build && bun run --filter 'platformer' build",
    "start": "bun run --filter 'platformer' start"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260322.1",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0"
  }
}
