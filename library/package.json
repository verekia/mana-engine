{
  "name": "mana-engine",
  "version": "0.0.1",
  "bin": {
    "mana": "./bin/mana.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./game": {
      "import": "./dist/game.js",
      "types": "./dist/game.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts src/game.ts src/cli.ts --outdir dist --format esm --splitting --packages=external && tsgo --emitDeclarationOnly",
    "test": "bun test"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@tailwindcss/vite": "4.2.2",
    "@vitejs/plugin-react": "6.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.2",
    "three": "0.183.2",
    "vite": "8.0.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.183.1",
    "happy-dom": "^20.8.4",
    "js-yaml": "^4.1.1"
  }
}
